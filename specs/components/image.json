{
  "name": "Image",
  "description": "Local image component",
  "aliases": [],
  "platforms": {
    "swift_generated": true,
    "swift_dynamic": true,
    "kotlin_generated": true,
    "kotlin_dynamic": true,
    "react": true
  },
  "attributes": {
    "src": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Image source name (can be data binding)"
    },
    "srcName": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Image source name (alias, can be data binding)"
    },
    "highlightSrc": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Image when highlighted (binding supported)"
    },
    "highlightSrcName": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Highlight image source name (binding supported)",
      "platform": "swift",
      "mode": "uikit"
    },
    "contentMode": {
      "type": [
        "string",
        "binding"
      ],
      "enum": [
        "fit",
        "fill",
        "center",
        "top",
        "bottom",
        "left",
        "right",
        "AspectFill",
        "AspectFit",
        "Center",
        "ScaleToFill",
        "Top",
        "Bottom",
        "Left",
        "Right"
      ],
      "description": "Content mode (binding supported)"
    },
    "renderingMode": {
      "type": "string",
      "enum": [
        "original",
        "template"
      ],
      "description": "Rendering mode"
    },
    "alt": {
      "type": "string",
      "description": "Alt text for accessibility",
      "platform": "react"
    },
    "loading": {
      "type": "string",
      "enum": [
        "lazy",
        "eager"
      ],
      "description": "Loading behavior",
      "platform": "react"
    }
  },
  "bindingBehavior": {
    "src": {
      "direction": "read-only"
    },
    "srcName": {
      "direction": "read-only"
    },
    "highlightSrc": {
      "direction": "read-only"
    },
    "highlightSrcName": {
      "direction": "read-only"
    },
    "contentMode": {
      "direction": "read-only"
    }
  },
  "platformSpecific": {
    "swift": {
      "view": "Image (with .resizable().aspectRatio())",
      "priority": "srcName > src > defaultImage",
      "circleImage": "type='CircleImage' adds .clipShape(Circle())"
    },
    "kotlin": {
      "composable": "Image with painterResource",
      "contentScale": "ContentScale.Fit/Crop/FillBounds"
    },
    "react": {
      "element": "<img/>",
      "objectFit": "aspectfit->contain, aspectfill->cover, scaletofill->fill"
    }
  },
  "rules": [
    ".resizable() must come first, then .aspectRatio (Swift)",
    "CircleImage type adds circular clipping",
    "contentMode maps differently per platform"
  ]
}