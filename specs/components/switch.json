{
  "name": "Switch",
  "description": "Toggle switch (iOS style)",
  "aliases": [],
  "platforms": {
    "swift_generated": true,
    "swift_dynamic": true,
    "kotlin_generated": true,
    "kotlin_dynamic": true,
    "react": true
  },
  "attributes": {
    "isOn": {
      "type": [
        "boolean",
        "binding"
      ],
      "description": "Switch state (binding for two-way)"
    },
    "value": {
      "type": [
        "boolean",
        "binding"
      ],
      "description": "Switch state alias (binding for two-way)"
    },
    "checked": {
      "type": [
        "boolean",
        "binding"
      ],
      "description": "Switch state alias (binding for two-way)"
    },
    "bind": {
      "type": "binding",
      "description": "Two-way binding @{variable}"
    },
    "enabled": {
      "type": [
        "boolean",
        "binding"
      ],
      "description": "Whether enabled (can be data binding)"
    },
    "tint": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Tint color - hex string or color name from colors.json (binding supported)"
    },
    "tintColor": {
      "type": "string",
      "description": "Tint color - hex string or color name from colors.json (alias)"
    },
    "onTintColor": {
      "type": "string",
      "description": "Track color when on - hex string or color name from colors.json"
    },
    "thumbTintColor": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Thumb tint color - hex string or color name from colors.json (binding supported)"
    },
    "offTintColor": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Off tint color - hex string or color name from colors.json (binding supported)",
      "platform": "swift",
      "mode": "uikit"
    },
    "onToggle": {
      "type": "string",
      "description": "Toggle handler function"
    },
    "onValueChange": {
      "type": "binding",
      "description": "Value change handler - binding only (@{functionName})"
    },
    "labelAttributes": {
      "type": "object",
      "description": "Label styling for Toggle",
      "properties": {
        "text": {
          "type": "string",
          "description": "Label text"
        },
        "font": {
          "type": "string",
          "description": "Font name"
        },
        "fontSize": {
          "type": "number",
          "description": "Font size"
        },
        "fontColor": {
          "type": "string",
          "description": "Font color - hex string or color name from colors.json"
        }
      }
    }
  },
  "bindingBehavior": {
    "isOn": {
      "direction": "two-way"
    },
    "value": {
      "direction": "two-way"
    },
    "checked": {
      "direction": "two-way"
    },
    "bind": {
      "direction": "two-way"
    },
    "enabled": {
      "direction": "read-only"
    },
    "tint": {
      "direction": "read-only"
    },
    "thumbTintColor": {
      "direction": "read-only"
    },
    "offTintColor": {
      "direction": "read-only"
    },
    "onValueChange": {
      "direction": "read-only"
    }
  },
  "platformSpecific": {
    "swift": {
      "view": "Toggle with switch style"
    },
    "kotlin": {
      "composable": "Switch"
    },
    "react": {
      "element": "Hidden checkbox + styled span (iOS-style toggle)"
    }
  },
  "rules": [
    "State binding priority: isOn > value > checked > bind",
    "Two-way binding updates via $data. (Swift) or updateData (Kotlin)",
    "onValueChange/onToggle for state change callback"
  ]
}