{
  "name": "TextView",
  "description": "Multi-line text input",
  "aliases": [],
  "platforms": {
    "swift_generated": true,
    "swift_dynamic": true,
    "kotlin_generated": true,
    "kotlin_dynamic": true,
    "react": true
  },
  "attributes": {
    "text": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Text content (binding for two-way)"
    },
    "hint": {
      "type": "string",
      "description": "Placeholder text (primary)"
    },
    "placeholder": {
      "type": "string",
      "description": "Placeholder text (alias for hint)"
    },
    "hintColor": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Placeholder color - hex string or color name from colors.json (binding supported)"
    },
    "hintFont": {
      "type": "string",
      "description": "Placeholder font"
    },
    "hintFontSize": {
      "type": "number",
      "description": "Placeholder font size"
    },
    "hintLineHeightMultiple": {
      "type": "number",
      "description": "Placeholder line height multiplier"
    },
    "hintAttributes": {
      "type": "object",
      "description": "Hint styling attributes"
    },
    "hideOnFocused": {
      "type": "boolean",
      "default": true,
      "description": "Hide placeholder when focused"
    },
    "font": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Font name or 'bold' (binding supported)"
    },
    "fontSize": {
      "type": [
        "number",
        "binding"
      ],
      "description": "Font size (binding supported)"
    },
    "fontColor": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Font color - hex string or color name from colors.json (binding supported)"
    },
    "textAlign": {
      "type": "string",
      "enum": [
        "Left",
        "Center",
        "Right",
        "left",
        "center",
        "right"
      ],
      "description": "Text alignment"
    },
    "containerInset": {
      "type": [
        "number",
        "array"
      ],
      "description": "Container inset"
    },
    "flexible": {
      "type": "boolean",
      "description": "Enable flexible height"
    },
    "input": {
      "type": "string",
      "enum": [
        "default",
        "alphabet",
        "allphabet",
        "email",
        "number",
        "phone",
        "url",
        "password",
        "decimal"
      ],
      "description": "Input type (includes 'allphabet' typo for backward compatibility)"
    },
    "returnKeyType": {
      "type": "string",
      "enum": [
        "Done",
        "Go",
        "Next",
        "Return",
        "Search",
        "Send",
        "Continue",
        "Join",
        "Route",
        "Yahoo",
        "Google"
      ],
      "description": "Return key type"
    },
    "editable": {
      "type": "boolean",
      "description": "Enable/disable editing"
    },
    "scrollEnabled": {
      "type": "boolean",
      "description": "Enable/disable scrolling"
    },
    "lineBreakMode": {
      "type": "string",
      "description": "Line break mode"
    },
    "dataDetectorTypes": {
      "type": "string",
      "description": "Data detector types",
      "platform": "swift",
      "mode": "uikit"
    },
    "allowsEditingTextAttributes": {
      "type": "boolean",
      "description": "Allow editing text attributes",
      "platform": "swift",
      "mode": "uikit"
    },
    "keyboardType": {
      "type": "string",
      "description": "Keyboard type"
    },
    "onTextChange": {
      "type": "string",
      "description": "Text change event selector"
    },
    "onBeginEditing": {
      "type": "string",
      "description": "Begin editing event handler",
      "platform": "swift",
      "mode": "uikit"
    },
    "onEndEditing": {
      "type": "string",
      "description": "End editing event handler",
      "platform": "swift",
      "mode": "uikit"
    },
    "onChangeSelection": {
      "type": "string",
      "description": "Selection change event handler",
      "platform": "swift",
      "mode": "uikit"
    },
    "onShouldChangeText": {
      "type": "string",
      "description": "Should change text event handler (return true to allow)",
      "platform": "swift",
      "mode": "uikit"
    },
    "onShouldBeginEditing": {
      "type": "string",
      "description": "Should begin editing event handler (return true to allow)",
      "platform": "swift",
      "mode": "uikit"
    },
    "onShouldEndEditing": {
      "type": "string",
      "description": "Should end editing event handler (return true to allow)",
      "platform": "swift",
      "mode": "uikit"
    },
    "maxLength": {
      "type": "number",
      "description": "Maximum input length",
      "platform": "react"
    },
    "pattern": {
      "type": "string",
      "description": "Input validation pattern",
      "platform": "react"
    },
    "required": {
      "type": "boolean",
      "description": "Required field validation",
      "platform": "react"
    },
    "selectable": {
      "type": "boolean",
      "description": "Whether text is selectable",
      "platform": "react"
    },
    "rows": {
      "type": "number",
      "description": "Number of visible rows",
      "platform": "react"
    },
    "cols": {
      "type": "number",
      "description": "Number of visible columns",
      "platform": "react"
    },
    "resize": {
      "type": "string",
      "enum": [
        "none",
        "both",
        "horizontal",
        "vertical"
      ],
      "description": "Resize behavior",
      "platform": "react"
    }
  },
  "bindingBehavior": {
    "text": {
      "direction": "two-way"
    },
    "hintColor": {
      "direction": "read-only"
    },
    "font": {
      "direction": "read-only"
    },
    "fontSize": {
      "direction": "read-only"
    },
    "fontColor": {
      "direction": "read-only"
    }
  },
  "platformSpecific": {
    "swift": {
      "view": "TextEditor"
    },
    "kotlin": {
      "composable": "OutlinedTextField with multiline"
    },
    "react": {
      "element": "<textarea>"
    }
  },
  "rules": [
    "text binding is two-way",
    "Multi-line input (unlike TextField which is single-line by default)"
  ]
}