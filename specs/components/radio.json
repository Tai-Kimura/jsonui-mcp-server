{
  "name": "Radio",
  "description": "Radio button group",
  "aliases": [],
  "platforms": {
    "swift_generated": true,
    "swift_dynamic": true,
    "kotlin_generated": true,
    "kotlin_dynamic": true,
    "react": true
  },
  "attributes": {
    "label": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Radio label (can be data binding)"
    },
    "text": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Radio label (alias, can be data binding)"
    },
    "group": {
      "type": "string",
      "required": true,
      "description": "Radio group name"
    },
    "icon": {
      "type": "string",
      "description": "Icon name for normal state"
    },
    "selectedIcon": {
      "type": "string",
      "description": "Selected icon name"
    },
    "selected_icon": {
      "type": "string",
      "description": "Selected icon name (underscore alias)"
    },
    "checked": {
      "type": [
        "boolean",
        "binding"
      ],
      "description": "Initial checked state (can be binding)"
    },
    "value": {
      "type": "any",
      "description": "Associated value when selected"
    },
    "font": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Font name (binding supported)"
    },
    "fontSize": {
      "type": [
        "number",
        "binding"
      ],
      "description": "Font size (binding supported)"
    },
    "fontColor": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Text color - hex string or color name from colors.json (binding supported)"
    },
    "spacing": {
      "type": [
        "number",
        "binding"
      ],
      "description": "Space between icon and text (binding supported)"
    }
  },
  "bindingBehavior": {
    "label": {
      "direction": "read-only"
    },
    "text": {
      "direction": "read-only"
    },
    "checked": {
      "direction": "read-only"
    },
    "font": {
      "direction": "read-only"
    },
    "fontSize": {
      "direction": "read-only"
    },
    "fontColor": {
      "direction": "read-only"
    },
    "spacing": {
      "direction": "read-only"
    }
  },
  "platformSpecific": {
    "swift": {
      "view": "Custom radio button implementation"
    },
    "kotlin": {
      "composable": "RadioButton in Row/Column"
    },
    "react": {
      "element": "<input type=\"radio\">"
    }
  },
  "rules": [
    "selectedIndex tracks currently selected option"
  ]
}