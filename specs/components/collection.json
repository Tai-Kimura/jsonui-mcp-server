{
  "name": "Collection",
  "description": "List/grid collection with data binding",
  "aliases": [],
  "platforms": {
    "swift_generated": true,
    "swift_dynamic": true,
    "kotlin_generated": true,
    "kotlin_dynamic": true,
    "react": true
  },
  "attributes": {
    "cellClasses": {
      "type": "array",
      "description": "Cell class definitions"
    },
    "headerClasses": {
      "type": "array",
      "description": "Header class definitions"
    },
    "footerClasses": {
      "type": "array",
      "description": "Footer class definitions"
    },
    "columns": {
      "type": "number",
      "min": 1,
      "description": "Number of columns"
    },
    "columnSpacing": {
      "type": "number",
      "description": "Spacing between columns"
    },
    "itemSpacing": {
      "type": "number",
      "description": "Spacing between items (used for both grid spacing and list item spacing)"
    },
    "lineSpacing": {
      "type": "number",
      "description": "Spacing between rows"
    },
    "horizontalScroll": {
      "type": "boolean",
      "description": "Enable horizontal scroll"
    },
    "orientation": {
      "type": "string",
      "enum": [
        "horizontal",
        "vertical"
      ],
      "description": "Scroll orientation (horizontal or vertical)"
    },
    "layout": {
      "type": "string",
      "enum": [
        "vertical",
        "horizontal",
        "flow",
        "Flow"
      ],
      "description": "Layout type (flow: wrapping layout based on content size)"
    },
    "insets": {
      "type": [
        "array",
        "string"
      ],
      "description": "Content insets"
    },
    "insetHorizontal": {
      "type": "number",
      "description": "Horizontal inset"
    },
    "insetVertical": {
      "type": "number",
      "description": "Vertical inset"
    },
    "contentInsets": {
      "type": [
        "array",
        "string"
      ],
      "description": "Content insets"
    },
    "contentInsetAdjustmentBehavior": {
      "type": "string",
      "description": "Content inset adjustment"
    },
    "itemWeight": {
      "type": "number",
      "description": "Item sizing weight"
    },
    "showsHorizontalScrollIndicator": {
      "type": "boolean",
      "description": "Show horizontal indicator"
    },
    "showsVerticalScrollIndicator": {
      "type": "boolean",
      "description": "Show vertical indicator"
    },
    "paging": {
      "type": "boolean",
      "description": "Enable paging"
    },
    "sections": {
      "type": "array",
      "description": "Section-based configuration",
      "items": {
        "type": "object",
        "properties": {
          "header": {
            "type": "string",
            "description": "Header view name"
          },
          "cell": {
            "type": "string",
            "description": "Cell view name"
          },
          "footer": {
            "type": "string",
            "description": "Footer view name"
          },
          "columns": {
            "type": "number",
            "description": "Section columns"
          }
        }
      }
    },
    "items": {
      "type": [
        "array",
        "binding"
      ],
      "description": "Data source binding"
    },
    "keyboardAvoidance": {
      "type": "boolean",
      "description": "Enable keyboard avoidance",
      "platform": "swift"
    },
    "setTargetAsDelegate": {
      "type": "boolean",
      "description": "Set target as delegate",
      "platform": "swift"
    },
    "setTargetAsDataSource": {
      "type": "boolean",
      "description": "Set target as data source",
      "platform": "swift"
    },
    "columnCount": {
      "type": "number",
      "description": "Number of columns for CSS grid",
      "platform": "react"
    },
    "scrollTo": {
      "type": "binding",
      "description": "PassthroughSubject<Int, Never> for programmatic scrolling to cell index"
    },
    "scrollAnchor": {
      "type": "string",
      "enum": [
        "top",
        "center",
        "bottom"
      ],
      "description": "Anchor point for scroll target (default: bottom)"
    },
    "defaultScrollAnchor": {
      "type": "string",
      "enum": [
        "top",
        "center",
        "bottom"
      ],
      "description": "Initial scroll position anchor (iOS 17+). Sets where the scroll view starts."
    },
    "scrollAnimated": {
      "type": "boolean",
      "description": "Whether scrollTo uses animation (default: true)"
    },
    "cellIdProperty": {
      "type": "string",
      "description": "Cell data property key to use as unique ID for ForEach identity. When set, scrollTo uses String type instead of Int."
    },
    "reverseLayout": {
      "type": "boolean",
      "description": "Reverse the layout direction of the Collection grid. When true, section order in the generated code is also reversed so that JSON definition order (index 0 first) matches the visual top-to-bottom order on iOS (which does not support reverseLayout). Compose's reverseLayout then flips the entire list so index 0 appears at the bottom.",
      "mode": "compose"
    },
    "scrollEnabled": {
      "type": [
        "boolean",
        "binding"
      ],
      "description": "Enable/disable scrolling (binding supported)"
    }
  },
  "bindingBehavior": {
    "items": {
      "direction": "read-only"
    },
    "scrollTo": {
      "direction": "read-only"
    },
    "scrollEnabled": {
      "direction": "read-only"
    }
  },
  "platformSpecific": {
    "swift": {
      "view": "LazyVStack/LazyHStack for performance",
      "sections": "Section-based with headers/footers",
      "flowLayout": "Flow layout support"
    },
    "kotlin": {
      "composable": "LazyColumn/LazyRow/LazyVerticalGrid",
      "sections": "Section-based with column count per section"
    },
    "react": {
      "element": "map() with component references",
      "cellFormat": "sections[].cell or cellClasses for component routing"
    }
  },
  "rules": [
    "items binding connects to data source array",
    "Sections support different cell types per section",
    "cellIdProperty extracts unique keys from item data",
    "scrollTo binding enables programmatic scrolling"
  ]
}