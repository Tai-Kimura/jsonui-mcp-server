{
  "name": "Label",
  "description": "Text display component",
  "aliases": [
    "Text"
  ],
  "platforms": {
    "swift_generated": true,
    "swift_dynamic": true,
    "kotlin_generated": true,
    "kotlin_dynamic": true,
    "react": true
  },
  "attributes": {
    "text": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Text content (can be data binding, supports interpolation)"
    },
    "hint": {
      "type": "string",
      "description": "Placeholder text when empty (primary)"
    },
    "placeholder": {
      "type": "string",
      "description": "Placeholder text when empty (alias for hint)"
    },
    "font": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Font name or 'bold' (can be data binding)"
    },
    "fontSize": {
      "type": [
        "number",
        "binding"
      ],
      "description": "Font size (can be data binding)"
    },
    "fontColor": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Font color - hex string or color name from colors.json (can be data binding)"
    },
    "fontFamily": {
      "type": "string",
      "description": "Font family name",
      "platform": "react"
    },
    "lineHeight": {
      "type": "number",
      "description": "Line height",
      "platform": "react"
    },
    "textTransform": {
      "type": "string",
      "enum": [
        "none",
        "capitalize",
        "uppercase",
        "lowercase"
      ],
      "description": "Text transformation",
      "platform": "react"
    },
    "selected": {
      "type": [
        "boolean",
        "binding"
      ],
      "description": "Selected state (binding supported)",
      "platform": "swift",
      "mode": "uikit"
    },
    "textAlign": {
      "type": [
        "string",
        "binding"
      ],
      "enum": [
        "Left",
        "Center",
        "Right",
        "left",
        "center",
        "right"
      ],
      "description": "Text alignment (binding supported)"
    },
    "lines": {
      "type": [
        "number",
        "binding"
      ],
      "min": 0,
      "description": "Maximum number of lines (0 for unlimited) (binding supported)"
    },
    "lineBreakMode": {
      "type": "string",
      "enum": [
        "Char",
        "Clip",
        "Word",
        "Head",
        "Middle",
        "Tail"
      ],
      "description": "Truncation mode"
    },
    "lineHeightMultiple": {
      "type": [
        "number",
        "binding"
      ],
      "min": 1,
      "description": "Line height multiplier (binding supported)"
    },
    "lineSpacing": {
      "type": [
        "number",
        "binding"
      ],
      "description": "Line spacing (binding supported)"
    },
    "edgeInset": {
      "type": [
        "array",
        "string"
      ],
      "description": "Edge insets as array or pipe-separated string"
    },
    "underline": {
      "type": [
        "boolean",
        "object",
        "array"
      ],
      "description": "Underline styling (boolean for simple, object for styled)",
      "properties": {
        "lineStyle": {
          "type": "string",
          "enum": [
            "Single",
            "Double",
            "Thick",
            "None"
          ],
          "description": "Underline style"
        },
        "color": {
          "type": "string",
          "description": "Underline color - hex string or color name from colors.json"
        },
        "lineOffset": {
          "type": "number",
          "description": "Baseline offset"
        }
      }
    },
    "strikethrough": {
      "type": [
        "boolean",
        "object"
      ],
      "description": "Strikethrough styling (boolean for simple, object for styled)",
      "properties": {
        "lineStyle": {
          "type": "string",
          "enum": [
            "Single",
            "Double",
            "Thick",
            "None"
          ],
          "description": "Strikethrough style"
        },
        "color": {
          "type": "string",
          "description": "Strikethrough color - hex string or color name from colors.json"
        }
      }
    },
    "autoShrink": {
      "type": "boolean",
      "description": "Enable auto-shrink"
    },
    "minimumScaleFactor": {
      "type": [
        "number",
        "binding"
      ],
      "min": 0,
      "max": 1,
      "description": "Minimum scale factor for auto-shrink (binding supported)"
    },
    "linkable": {
      "type": [
        "boolean",
        "binding"
      ],
      "description": "Enable URL/phone detection"
    },
    "textShadow": {
      "type": [
        "string",
        "object"
      ],
      "description": "Text shadow configuration"
    },
    "hintColor": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Hint text color - hex string or color name from colors.json (binding supported)"
    },
    "highlightAttributes": {
      "type": "object",
      "description": "Highlight styling attributes when selected",
      "properties": {
        "font": {
          "type": "string",
          "description": "Font name"
        },
        "fontSize": {
          "type": "number",
          "description": "Font size"
        },
        "fontColor": {
          "type": "string",
          "description": "Font color - hex string or color name from colors.json"
        },
        "lineHeightMultiple": {
          "type": "number",
          "description": "Line height multiplier"
        },
        "textAlign": {
          "type": "string",
          "enum": [
            "Left",
            "Right",
            "Center"
          ],
          "description": "Text alignment"
        }
      }
    },
    "highlightColor": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Font color when selected - hex string or color name from colors.json (binding supported)"
    },
    "partialAttributes": {
      "type": "array",
      "description": "Partial text styling",
      "items": {
        "type": "object",
        "properties": {
          "font": {
            "type": "string",
            "description": "Font name"
          },
          "fontSize": {
            "type": "number",
            "description": "Font size"
          },
          "fontColor": {
            "type": "string",
            "description": "Font color - hex string or color name from colors.json"
          },
          "lineSpacing": {
            "type": "number",
            "description": "Line spacing"
          },
          "lineHeightMultiple": {
            "type": "number",
            "description": "Line height multiplier"
          },
          "lineBreakMode": {
            "type": "string",
            "enum": [
              "Char",
              "Clip",
              "Word",
              "Head",
              "Middle",
              "Tail"
            ],
            "description": "Line break mode"
          },
          "textAlign": {
            "type": "string",
            "enum": [
              "Left",
              "Right",
              "Center"
            ],
            "description": "Text alignment"
          },
          "underline": {
            "type": "object",
            "properties": {
              "lineStyle": {
                "type": "string",
                "enum": [
                  "Single",
                  "Double",
                  "Thick",
                  "None"
                ],
                "description": "Underline style"
              },
              "color": {
                "type": "string",
                "description": "Underline color - hex string or color name from colors.json"
              },
              "lineOffset": {
                "type": "number",
                "description": "Baseline offset"
              }
            }
          },
          "textShadow": {
            "type": "string",
            "description": "Text shadow"
          },
          "range": {
            "type": [
              "array",
              "string"
            ],
            "description": "Range [start, end], text pattern string, or binding expression"
          },
          "onclick": {
            "type": "string",
            "description": "Click handler for this range (selector-based, lowercase)"
          },
          "onClick": {
            "type": "binding",
            "description": "Click handler for this range (camelCase) - binding only (@{functionName})"
          }
        }
      }
    },
    "hintAttributes": {
      "type": "object",
      "description": "Hint text styling attributes",
      "properties": {
        "font": {
          "type": "string",
          "description": "Font name"
        },
        "fontSize": {
          "type": "number",
          "description": "Font size"
        },
        "fontColor": {
          "type": "string",
          "description": "Font color - hex string or color name from colors.json"
        },
        "lineHeightMultiple": {
          "type": "number",
          "description": "Line height multiplier"
        }
      }
    },
    "fontWeight": {
      "type": [
        "string",
        "number"
      ],
      "description": "Font weight (e.g., 'bold', 'semibold', '500', 600)"
    }
  },
  "bindingBehavior": {
    "text": {
      "direction": "read-only"
    },
    "font": {
      "direction": "read-only"
    },
    "fontSize": {
      "direction": "read-only"
    },
    "fontColor": {
      "direction": "read-only"
    },
    "selected": {
      "direction": "read-only"
    },
    "textAlign": {
      "direction": "read-only"
    },
    "lines": {
      "direction": "read-only"
    },
    "lineHeightMultiple": {
      "direction": "read-only"
    },
    "lineSpacing": {
      "direction": "read-only"
    },
    "minimumScaleFactor": {
      "direction": "read-only"
    },
    "linkable": {
      "direction": "read-only"
    },
    "hintColor": {
      "direction": "read-only"
    },
    "highlightColor": {
      "direction": "read-only"
    }
  },
  "platformSpecific": {
    "swift": {
      "view": "Text",
      "partialAttributes": "Supports styled text ranges via partialAttributes array",
      "alignment": ".leading alignment added to frame for textAlign to work"
    },
    "kotlin": {
      "composable": "Text",
      "partialAttributes": "AnnotatedString with SpanStyle for styled ranges"
    },
    "react": {
      "element": "<span>",
      "lineClamping": "lines:1 -> truncate, lines:2+ -> line-clamp-N"
    }
  },
  "rules": [
    "text attribute supports interpolation with @{binding} syntax",
    "partialAttributes allows styling ranges within text",
    "linkable enables auto-detection of URLs",
    "Frame alignment must be .leading for textAlign to work correctly (Swift)"
  ]
}