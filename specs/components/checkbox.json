{
  "name": "CheckBox",
  "description": "Checkbox input",
  "aliases": [
    "Check",
    "Checkbox"
  ],
  "platforms": {
    "swift_generated": true,
    "swift_dynamic": true,
    "kotlin_generated": true,
    "kotlin_dynamic": true,
    "react": true
  },
  "attributes": {
    "label": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Checkbox label (can be data binding)"
    },
    "text": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Checkbox label (alias, can be data binding)"
    },
    "isOn": {
      "type": [
        "boolean",
        "binding"
      ],
      "description": "Checked state (binding for two-way)"
    },
    "checked": {
      "type": [
        "boolean",
        "binding"
      ],
      "description": "Checked state alias (binding for two-way)"
    },
    "bind": {
      "type": "binding",
      "description": "Two-way binding @{variable}"
    },
    "icon": {
      "type": "string",
      "description": "Icon name for unchecked state"
    },
    "src": {
      "type": "string",
      "description": "Icon name for unchecked state (alias)"
    },
    "selectedIcon": {
      "type": "string",
      "description": "Selected icon name"
    },
    "onSrc": {
      "type": "string",
      "description": "Selected icon name (alias)"
    },
    "value": {
      "type": "any",
      "description": "Associated value when checked"
    },
    "enabled": {
      "type": [
        "boolean",
        "binding"
      ],
      "description": "Whether enabled (can be data binding)"
    },
    "font": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Font name (binding supported)"
    },
    "fontSize": {
      "type": [
        "number",
        "binding"
      ],
      "description": "Font size (binding supported)"
    },
    "fontColor": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Text color - hex string or color name from colors.json (binding supported)"
    },
    "spacing": {
      "type": [
        "number",
        "binding"
      ],
      "description": "Space between icon and text (binding supported)"
    },
    "onValueChange": {
      "type": "binding",
      "description": "Value change handler - binding only (@{functionName})"
    }
  },
  "bindingBehavior": {
    "label": {
      "direction": "read-only"
    },
    "text": {
      "direction": "read-only"
    },
    "isOn": {
      "direction": "two-way"
    },
    "checked": {
      "direction": "two-way"
    },
    "bind": {
      "direction": "two-way"
    },
    "enabled": {
      "direction": "read-only"
    },
    "font": {
      "direction": "read-only"
    },
    "fontSize": {
      "direction": "read-only"
    },
    "fontColor": {
      "direction": "read-only"
    },
    "spacing": {
      "direction": "read-only"
    },
    "onValueChange": {
      "direction": "read-only"
    }
  },
  "platformSpecific": {
    "swift": {
      "view": "Toggle with checkbox style"
    },
    "kotlin": {
      "composable": "Checkbox or IconToggleButton (custom icons)"
    },
    "react": {
      "element": "<input type=\"checkbox\">"
    }
  },
  "rules": [
    "Kotlin supports custom icon/selectedIcon via IconToggleButton",
    "checked is primary binding attribute"
  ]
}