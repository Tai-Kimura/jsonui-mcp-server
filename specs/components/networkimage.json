{
  "name": "NetworkImage",
  "description": "Remote/network image component",
  "aliases": [],
  "platforms": {
    "swift_generated": true,
    "swift_dynamic": true,
    "kotlin_generated": true,
    "kotlin_dynamic": true,
    "react": true
  },
  "attributes": {
    "src": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Image URL (can be data binding)"
    },
    "url": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Image URL (alias, can be data binding)"
    },
    "hint": {
      "type": "string",
      "description": "Placeholder image name (primary)"
    },
    "placeholder": {
      "type": "string",
      "description": "Placeholder image name (alias for hint)"
    },
    "defaultImage": {
      "type": "string",
      "description": "Default image name"
    },
    "errorImage": {
      "type": "string",
      "description": "Error image name"
    },
    "loadingImage": {
      "type": "string",
      "description": "Loading image name"
    },
    "contentMode": {
      "type": [
        "string",
        "binding"
      ],
      "enum": [
        "fit",
        "fill",
        "center",
        "top",
        "bottom",
        "left",
        "right",
        "AspectFill",
        "AspectFit",
        "Center"
      ],
      "description": "Content mode (binding supported)"
    },
    "cachePolicy": {
      "type": "string",
      "description": "Cache policy",
      "platform": "swift",
      "mode": "uikit"
    },
    "timeout": {
      "type": "number",
      "description": "Download timeout in seconds",
      "platform": "swift",
      "mode": "uikit"
    },
    "alt": {
      "type": "string",
      "description": "Alt text for accessibility",
      "platform": "react"
    },
    "loading": {
      "type": "string",
      "enum": [
        "lazy",
        "eager"
      ],
      "description": "Loading behavior",
      "platform": "react"
    }
  },
  "bindingBehavior": {
    "src": {
      "direction": "read-only"
    },
    "url": {
      "direction": "read-only"
    },
    "contentMode": {
      "direction": "read-only"
    }
  },
  "platformSpecific": {
    "swift": {
      "view": "AsyncImage or custom NetworkImageView",
      "defaultContentMode": ".center for matchParent"
    },
    "kotlin": {
      "composable": "AsyncImage (Coil)"
    },
    "react": {
      "element": "<img/> with src binding"
    }
  },
  "rules": [
    "Default contentMode is .center for matchParent (Swift)",
    "Supports placeholder/error images via defaultImage"
  ]
}