{
  "name": "Segment",
  "description": "Segmented control",
  "aliases": [],
  "platforms": {
    "swift_generated": true,
    "swift_dynamic": true,
    "kotlin_generated": true,
    "kotlin_dynamic": true,
    "react": true
  },
  "attributes": {
    "items": {
      "type": "array",
      "required": true,
      "description": "Segment items array"
    },
    "selectedIndex": {
      "type": [
        "number",
        "binding"
      ],
      "description": "Initially selected index (binding for two-way)"
    },
    "tintColor": {
      "type": "string",
      "description": "Tint color - hex string or color name from colors.json"
    },
    "normalColor": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Normal state color - hex string or color name from colors.json (binding supported)"
    },
    "selectedColor": {
      "type": [
        "string",
        "binding"
      ],
      "description": "Selected state color - hex string or color name from colors.json (binding supported)"
    },
    "valueChange": {
      "type": "string",
      "description": "Value change event"
    },
    "momentary": {
      "type": "boolean",
      "description": "Momentary selection mode",
      "platform": "swift",
      "mode": "uikit"
    },
    "apportionsSegmentWidthsByContent": {
      "type": "boolean",
      "description": "Size segments by content",
      "platform": "swift",
      "mode": "uikit"
    },
    "onValueChange": {
      "type": "binding",
      "description": "Value change handler - binding only (@{functionName})"
    }
  },
  "bindingBehavior": {
    "selectedIndex": {
      "direction": "two-way"
    },
    "normalColor": {
      "direction": "read-only"
    },
    "selectedColor": {
      "direction": "read-only"
    },
    "onValueChange": {
      "direction": "read-only"
    }
  },
  "platformSpecific": {
    "swift": {
      "view": "Picker with segmented style"
    },
    "kotlin": {
      "composable": "TabRow or custom segment"
    },
    "react": {
      "element": "Button group with useState for selectedIndex"
    }
  },
  "rules": [
    "Without binding, React auto-generates useState for selectedIndex",
    "selectedIndex tracks active segment"
  ]
}